<!DOCTYPE html>
<html lang="fr"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Atlas agricole — adaptation/s</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{--ink:#1f2733;--sub:#5b6675;--line:#e7e9ee;--bg:#fbfbfa;--card:#fff;--accent:#9c4a06;--brand:#abff00;}
  *{box-sizing:border-box}
  html,body{margin:0;background:var(--bg);color:var(--ink);
    font-family:'Manrope',-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    -webkit-font-smoothing:antialiased}
  .wrap{max-width:1280px;margin:0 auto;padding:26px 26px 40px}
  .logo{height:46px;width:auto;display:block;border-radius:8px}
  .top{display:flex;justify-content:space-between;align-items:flex-start;gap:24px}
  .eyebrow{font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--sub);font-weight:700}
  h1{font-weight:800;font-size:38px;line-height:1.04;margin:8px 0 2px;letter-spacing:-.025em}
  .lede{color:var(--sub);font-size:15px;font-weight:500;margin:0 0 22px;max-width:62ch}
  .app{display:grid;grid-template-columns:312px 1fr;gap:26px;align-items:start}
  .panel{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:18px}
  .panel+.panel{margin-top:16px}
  .grouptitle{font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--sub);font-weight:700;margin:0 0 10px}
  .crop{display:flex;align-items:center;gap:12px;width:100%;text-align:left;cursor:pointer;border:1px solid transparent;background:transparent;padding:8px 10px;border-radius:10px;font-size:15px;font-weight:500;color:var(--ink);transition:.15s;font-family:inherit}
  .crop:hover{background:#f4f5f7}.crop.active{border-color:var(--line);background:#f7f8fa;font-weight:700}
  .cic{width:26px;height:26px;flex:0 0 auto;display:flex;align-items:center;justify-content:center}
  .cic svg{width:26px;height:26px}
  .toggle{display:flex;background:#f1f2f5;border-radius:10px;padding:3px;gap:3px}
  .toggle button{flex:1;border:0;background:transparent;padding:8px 6px;border-radius:8px;font-size:13px;color:var(--sub);cursor:pointer;font-weight:700;font-family:inherit}
  .toggle button.on{background:#fff;color:var(--ink);box-shadow:0 1px 2px rgba(0,0,0,.08)}
  .stat-label{font-size:12.5px;color:var(--sub);font-weight:500}
  .stat-val{font-weight:800;font-size:30px;color:var(--accent);line-height:1.1;margin-top:2px;letter-spacing:-.02em}
  .stat-unit{font-size:15px;font-weight:700}
  .legend{display:flex;flex-direction:column;gap:7px}
  .lgrow{display:flex;align-items:center;gap:9px;font-size:12.5px;color:var(--ink);font-weight:500}
  .sw{width:18px;height:14px;border-radius:3px;flex:0 0 auto;border:1px solid rgba(0,0,0,.05)}
  .sw.nd{background:repeating-linear-gradient(45deg,#e9ecef,#e9ecef 3px,#fff 3px,#fff 5px)}
  .top5 .t{display:flex;align-items:center;gap:10px;font-size:13.5px;padding:5px 0;font-weight:500}
  .rank{width:21px;height:21px;border-radius:50%;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex:0 0 auto}
  .top5 .nm{flex:1}.top5 .vl{color:var(--sub);font-weight:700}
  .mapcard{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:8px;position:relative}
  svg.map{width:100%;height:auto;display:block}
  path.dep{stroke:#fff;stroke-width:.6;transition:fill .25s,opacity .15s;cursor:pointer}
  path.dep:hover{opacity:.82}path.dep.hl{stroke:#1f2733;stroke-width:1.4}
  .tip{position:fixed;pointer-events:none;background:#1f2733;color:#fff;padding:9px 12px;border-radius:9px;font-size:13px;font-weight:500;line-height:1.35;opacity:0;transition:opacity .12s;z-index:60;max-width:230px;box-shadow:0 6px 22px rgba(0,0,0,.22)}
  .tip b{font-size:14px;font-weight:700}.tip .r{color:#aeb7c4;font-size:11.5px}.tip .big{font-weight:800;font-size:16px;margin-top:3px}
  .foot{color:#9aa3b0;font-size:12px;margin-top:18px;line-height:1.5;font-weight:500}
  .gate{position:fixed;inset:0;background:#f4f5f7;display:flex;align-items:center;justify-content:center;z-index:100;padding:24px}
  .gatecard{background:#fff;border:1px solid var(--line);border-radius:18px;padding:34px 32px;max-width:392px;width:100%;box-shadow:0 20px 60px rgba(20,30,50,.10);text-align:center}
  .gatecard .logo{height:54px;margin:0 auto 6px}
  .gate h2{font-weight:800;font-size:20px;margin:20px 0 4px;letter-spacing:-.02em}
  .gate p{color:var(--sub);font-size:13.5px;font-weight:500;margin:0 0 20px;line-height:1.5}
  .gate input{width:100%;padding:13px 14px;border:1.5px solid var(--line);border-radius:11px;font-size:15px;font-family:inherit;font-weight:500;outline:none;transition:.15s}
  .gate input:focus{border-color:var(--ink)}
  .gate button{width:100%;margin-top:12px;padding:13px;border:0;border-radius:11px;background:var(--ink);color:#fff;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;transition:.15s}
  .gate button:hover{background:#0f1620}.gate button:disabled{opacity:.6;cursor:default}
  .gate .err{color:#c0392b;font-size:13px;font-weight:600;margin-top:12px;min-height:18px}
  .gate .lock{font-size:12px;color:#9aa3b0;margin-top:18px;font-weight:500}
  .hidden{display:none!important}
  @media(max-width:860px){.app{grid-template-columns:1fr}h1{font-size:30px}.top{flex-direction:column-reverse;align-items:flex-start}}
</style></head>
<body>

<div class="gate" id="gate">
  <div class="gatecard">
    <img class="logo" alt="adaptation/s" src="data:image/png;base64,">
    <h2>Accès protégé</h2>
    <p>Cette page est réservée. Saisissez le code d’accès communiqué pour consulter l’atlas.</p>
    <input id="pw" type="password" placeholder="Code d’accès" autocomplete="off" autofocus>
    <button id="unlock">Ouvrir l’atlas</button>
    <div class="err" id="err"></div>
    <div class="lock">🔒 Données chiffrées (AES-256). Le contenu reste illisible sans le bon code.</div>
  </div>
</div>

<div class="wrap hidden" id="appwrap">
  <div class="top">
    <div>
      <div class="eyebrow">Atlas agricole · Agreste — Statistique agricole annuelle</div>
      <h1 id="title">Production agricole en France</h1>
      <p class="lede">Surfaces cultivées et production laitière par département, année 2025. Survolez la carte pour le détail ; changez de filière ou basculez vers l’évolution depuis 2010.</p>
    </div>
    <img class="logo" alt="adaptation/s" src="data:image/png;base64,">
  </div>
  <div class="app">
    <aside>
      <div class="panel"><div class="grouptitle">Filière</div><div id="crops"></div></div>
      <div class="panel"><div class="grouptitle">Indicateur</div>
        <div class="toggle" id="metric"><button data-m="level" class="on">Niveau 2025</button><button data-m="evol">Évolution 2010→25</button></div>
        <div style="margin-top:16px"><div class="stat-label" id="statLabel">Surface nationale 2025</div>
          <div class="stat-val"><span id="statVal"></span> <span class="stat-unit" id="statUnit"></span></div></div>
        <div style="margin-top:16px"><div class="grouptitle" style="margin-bottom:8px" id="legTitle">Hectares</div>
          <div class="legend" id="legend"></div></div>
      </div>
      <div class="panel top5"><div class="grouptitle">Top 5 départements (2025)</div><div id="top5"></div></div>
    </aside>
    <main>
      <div class="mapcard"><svg class="map" id="map" viewBox="0 0 1000 1040" role="img" aria-label="Carte choroplèthe des départements français"></svg></div>
      <p class="foot">Source : Agreste — Statistique agricole annuelle (SSP / Ministère de l’Agriculture). France métropolitaine ; séries calées sur le recensement agricole 2020. Données 2025 <b>provisoires</b>. Hachures = donnée non disponible ou secret statistique (ex. Paris). Lait = production finale de lait de vache (hl).</p>
    </main>
  </div>
</div>

<div class="tip" id="tip"></div>

<script>
var ENC={"salt":"UeDZPgVGEKt4wuKfRI4+MA==","iv":"LNp1dO6b+Xnvhy+Q","ct":"","iter":250000};
var ORDER=["ble_tendre","colza","pdt","pomme","lait"];
var ICONS={
ble_tendre:'<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 21V8" fill="none"/><path stroke="none" d="M12 7.4c0-2 1.2-3.4 3-3.4 0 2-1.2 3.4-3 3.4Z"/><path stroke="none" d="M12 11c-1.8 0-3-1.2-3-3 1.8 0 3 1.2 3 3Z"/><path stroke="none" d="M12 11c1.8 0 3-1.2 3-3-1.8 0-3 1.2-3 3Z"/><path stroke="none" d="M12 15c-1.8 0-3-1.2-3-3 1.8 0 3 1.2 3 3Z"/><path stroke="none" d="M12 15c1.8 0 3-1.2 3-3-1.8 0-3 1.2-3 3Z"/><path stroke="none" d="M12 19c-1.8 0-3-1.2-3-3 1.8 0 3 1.2 3 3Z"/><path stroke="none" d="M12 19c1.8 0 3-1.2 3-3-1.8 0-3 1.2-3 3Z"/></svg>',
colza:'<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="6.6" r="2.7"/><circle cx="6.7" cy="10.4" r="2.7"/><circle cx="8.7" cy="16.6" r="2.7"/><circle cx="15.3" cy="16.6" r="2.7"/><circle cx="17.3" cy="10.4" r="2.7"/><circle cx="12" cy="12" r="2.9" fill="#fff"/><circle cx="12" cy="12" r="1.5"/></svg>',
pdt:'<svg viewBox="0 0 24 24" fill="currentColor"><ellipse cx="12" cy="12" rx="9.2" ry="6.6" transform="rotate(-18 12 12)"/><circle cx="9" cy="10.6" r="1" fill="#fff" opacity=".6"/><circle cx="13.2" cy="9.6" r="0.9" fill="#fff" opacity=".6"/><circle cx="14.6" cy="13.8" r="1" fill="#fff" opacity=".6"/><circle cx="10.4" cy="14" r="0.85" fill="#fff" opacity=".6"/></svg>',
pomme:'<svg viewBox="0 0 24 24" fill="currentColor"><rect x="11.5" y="3" width="1" height="3.4" rx=".5"/><path d="M12.6 6.4c.2-1.5 1.4-2.7 3-2.8-.1 1.5-1.3 2.7-3 2.8Z" fill="#4a8f3c"/><path d="M15.7 6.2c-1.5 0-2.7.7-3.5 1.5-.8-.8-2-1.5-3.5-1.5C6 6.2 4 8.6 4 11.9c0 3.7 2.5 8.1 5.7 8.1.9 0 1.6-.3 2.3-.7.7.4 1.4.7 2.3.7 3.2 0 5.7-4.4 5.7-8.1 0-3.3-2-5.7-4.3-5.7Z"/></svg>',
lait:'<svg viewBox="0 0 24 24"><path d="M9.2 2.6h5.6v2.3l1.6 2.6c.26.45.4.96.4 1.48V19.4c0 1.1-.9 2-2 2H9.2c-1.1 0-2-.9-2-2V8.98c0-.52.14-1.03.4-1.48L9.2 4.9V2.6Z" fill="#f4f2ea" stroke="#7e8794" stroke-width="1.2"/><rect x="7.7" y="12" width="8.6" height="3.3" fill="#cfe0ef"/><line x1="9.2" y1="5" x2="14.8" y2="5" stroke="#7e8794" stroke-width="1.2"/></svg>'
};
var ICONCOL={ble_tendre:'#BE8A2E',colza:'#EFC200',pdt:'#9A6A3A',pomme:'#CC3A2E',lait:'#7e8794'};
var DIV=["#c0392b","#ef8a62","#f2f1ee","#9ed154","#2f7d2f"];
var EVBRK=[-1e9,-30,-10,10,30,1e9];
var EVLBL=["Baisse > 30 %","\u221230 \u00e0 \u221210 %","\u221210 \u00e0 +10 %","+10 \u00e0 +30 %","Hausse > 30 %"];
var SVGNS="http://www.w3.org/2000/svg";
var APP=null, state={crop:"ble_tendre",metric:"level"};
function $(s){return document.querySelector(s)}
var tip=$("#tip");
function b64(s){var bin=atob(s),u=new Uint8Array(bin.length);for(var i=0;i<bin.length;i++)u[i]=bin.charCodeAt(i);return u}
function fmt(v){return Math.round(v).toLocaleString("fr-FR").replace(/\u202f/g," ")}
function shortn(v){if(v>=1e6)return (v/1e6).toFixed(1).replace(".0","")+" M";if(v>=1e3)return Math.round(v/1e3)+" k";return ""+Math.round(v)}

async function tryUnlock(){
  var pw=$("#pw").value, btn=$("#unlock"), err=$("#err");
  if(!pw){err.textContent="Veuillez saisir le code.";return}
  if(!(window.crypto&&window.crypto.subtle)){err.textContent="Ouvrez la page via le lien hébergé (https) pour activer l’accès.";return}
  btn.disabled=true; btn.textContent="Déchiffrement…"; err.textContent="";
  try{
    var base=await crypto.subtle.importKey('raw',new TextEncoder().encode(pw),'PBKDF2',false,['deriveKey']);
    var key=await crypto.subtle.deriveKey({name:'PBKDF2',salt:b64(ENC.salt),iterations:ENC.iter,hash:'SHA-256'},
            base,{name:'AES-GCM',length:256},false,['decrypt']);
    var pt=await crypto.subtle.decrypt({name:'AES-GCM',iv:b64(ENC.iv)},key,b64(ENC.ct));
    APP=JSON.parse(new TextDecoder().decode(pt));
    boot();
    $("#gate").classList.add("hidden"); $("#appwrap").classList.remove("hidden");
  }catch(e){
    btn.disabled=false; btn.textContent="Ouvrir l’atlas";
    err.textContent="Code incorrect. Réessayez."; $("#pw").select();
  }
}
function classLevel(c,v){if(v==null)return -1;var br=c.breaks;for(var i=4;i>=1;i--){if(v>=br[i])return i}return 0}
function classEvol(v){if(v==null)return -1;for(var i=0;i<5;i++){if(v>EVBRK[i]&&v<=EVBRK[i+1])return i}return 0}
function colorFor(c,code){if(state.metric==="level"){var i=classLevel(c,c.level[code]);return i<0?null:c.pal[i]}var j=classEvol(c.evol[code]);return j<0?null:DIV[j]}
function featByCode(code){for(var i=0;i<APP.feats.length;i++){if(APP.feats[i].code===code)return APP.feats[i]}return null}
function buildMap(){
  var svg=$("#map");
  var defs=document.createElementNS(SVGNS,"defs");
  defs.innerHTML='<pattern id="nd" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(45)"><rect width="6" height="6" fill="#eef0f2"/><rect width="3" height="6" fill="#dfe3e8"/></pattern>';
  svg.appendChild(defs);
  APP.feats.forEach(function(f){
    var p=document.createElementNS(SVGNS,"path");
    p.setAttribute("d",f.d); p.setAttribute("class","dep"); p.setAttribute("data-code",f.code);
    p.addEventListener("mousemove",showTip);
    p.addEventListener("mouseenter",function(){p.classList.add("hl")});
    p.addEventListener("mouseleave",function(){p.classList.remove("hl");tip.style.opacity=0});
    svg.appendChild(p);
  });
}
function buildCrops(){
  var el=$("#crops"); el.innerHTML="";
  ORDER.forEach(function(k){
    var c=APP.crops[k], b=document.createElement("button");
    b.className="crop"+(k===state.crop?" active":""); b.setAttribute("data-k",k);
    b.innerHTML='<span class="cic" style="color:'+ICONCOL[k]+'">'+ICONS[k]+'</span>'+c.label;
    b.addEventListener("click",function(){state.crop=k;rerender()});
    el.appendChild(b);
  });
}
function paint(){var c=APP.crops[state.crop];var ps=document.querySelectorAll("path.dep");for(var i=0;i<ps.length;i++){var col=colorFor(c,ps[i].getAttribute("data-code"));ps[i].setAttribute("fill",col||"url(#nd)")}}
function renderLegend(){var c=APP.crops[state.crop],leg=$("#legend"),h="";
  if(state.metric==="level"){$("#legTitle").textContent=c.unit==="hl"?"Hectolitres":"Hectares";
    for(var i=4;i>=0;i--){h+='<div class="lgrow"><span class="sw" style="background:'+c.pal[i]+'"></span>'+shortn(c.breaks[i])+' \u2013 '+shortn(c.breaks[i+1])+'</div>'}}
  else{$("#legTitle").textContent="Variation 2010 \u2192 2025";
    for(var k=4;k>=0;k--){h+='<div class="lgrow"><span class="sw" style="background:'+DIV[k]+'"></span>'+EVLBL[k]+'</div>'}}
  h+='<div class="lgrow"><span class="sw nd"></span>Non disponible</div>';leg.innerHTML=h}
function renderStat(){var c=APP.crops[state.crop];$("#statLabel").textContent=(c.kind==="Surface"?"Surface":"Production")+" nationale 2025";$("#statVal").textContent=fmt(c.total);$("#statUnit").textContent=c.unit;document.documentElement.style.setProperty("--accent",c.pal[4])}
function renderTop5(){var c=APP.crops[state.crop];var a=APP.feats.map(function(f){return{nom:f.nom,v:c.level[f.code]}}).filter(function(o){return o.v!=null}).sort(function(x,y){return y.v-x.v}).slice(0,5);
  $("#top5").innerHTML=a.map(function(o,i){return '<div class="t"><span class="rank" style="background:'+c.pal[4]+'">'+(i+1)+'</span><span class="nm">'+o.nom+'</span><span class="vl">'+fmt(o.v)+' '+c.unit+'</span></div>'}).join("")}
function setActiveCrop(){var bs=document.querySelectorAll(".crop");for(var i=0;i<bs.length;i++){bs[i].className="crop"+(bs[i].getAttribute("data-k")===state.crop?" active":"")}}
function showTip(e){var p=e.currentTarget,code=p.getAttribute("data-code"),f=featByCode(code);if(!f)return;
  var c=APP.crops[state.crop],lv=c.level[code],ev=c.evol[code],body;
  if(lv==null){body='<div class="big">Donn\u00e9e non disponible</div>'}
  else if(state.metric==="level"){body='<div class="big">'+fmt(lv)+' '+c.unit+'</div>';if(ev!=null)body+='<div class="r">'+(ev>=0?"+":"")+(ev.toFixed(1).replace(".",","))+' % depuis 2010</div>'}
  else{body= ev==null?'<div class="big">n.d.</div>':'<div class="big">'+(ev>=0?"+":"")+ev.toFixed(1).replace(".",",")+' %</div><div class="r">'+fmt(lv)+' '+c.unit+' en 2025</div>'}
  tip.innerHTML='<b>'+f.nom+'</b> <span class="r">'+f.region+'</span>'+body;tip.style.opacity=1;
  var pad=14,x=e.clientX+pad,y=e.clientY+pad,r=tip.getBoundingClientRect();
  if(x+r.width>window.innerWidth-8)x=e.clientX-r.width-pad;if(y+r.height>window.innerHeight-8)y=e.clientY-r.height-pad;
  tip.style.left=x+"px";tip.style.top=y+"px"}
function rerender(){setActiveCrop();$("#title").textContent=APP.crops[state.crop].label;renderStat();renderLegend();renderTop5();paint()}
function boot(){
  buildMap(); buildCrops(); rerender();
  $("#metric").addEventListener("click",function(e){var b=e.target;if(b.tagName!=="BUTTON")return;state.metric=b.getAttribute("data-m");var mb=document.querySelectorAll("#metric button");for(var k=0;k<mb.length;k++){mb[k].className=(mb[k]===b?"on":"")}renderLegend();paint()});
}
$("#unlock").addEventListener("click",tryUnlock);
$("#pw").addEventListener("keydown",function(e){if(e.key==="Enter")tryUnlock()});
</script>
</body></html>
